{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DOI Checker",
  "version": "0.3.1",
  "identifier": "com.urschrei.doicheck",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "DOI Checker",
        "width": 1080,
        "height": 820,
        "minWidth": 720,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    },
    "resources": [
      "pdfium/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/urschrei/doicheck/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCNTVDRTIwOTJCQTMyOUQKUldTZE1ycVNJTTVWZStJUUtnNzlvOFN2RFNSUVBnYU9TOW5UNGkwZ2F0RVF4Smh0UUtkV2hhRzMK"
    }
  }
}